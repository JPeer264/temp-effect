{
  "name": "temp-effect",
  "version": "1.0.0",
  "description": "React + Effect.ts full-stack application",
  "scripts": {
    "dev": "concurrently \"pnpm dev:api\" \"pnpm dev:frontend\"",
    "dev:api": "tsx --watch src/api/main.ts",
    "dev:frontend": "vite",
    "build": "vite build",
    "check": "tsc -b tsconfig.json"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.25.0",
  "pnpm": {
    "overrides": {
      "@sentry/core": "file:.yalc/@sentry/core",
      "@sentry/node": "file:.yalc/@sentry/node"
    }
  },
  "devDependencies": {
    "@types/node": "^22.8.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "@effect/opentelemetry": "^0.61.0",
    "@effect/platform": "^0.94.5",
    "@effect/platform-node": "^0.104.1",
    "@effect/sql": "^0.49.0",
    "@effect/sql-pg": "^0.50.3",
    "@sentry/core": "file:.yalc/@sentry/core",
    "@sentry/node": "file:.yalc/@sentry/node",
    "@sentry/react": "^10.41.0",
    "effect": "^3.19.19",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
